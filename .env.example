# =====================================================
# ChatMandarin 环境变量配置
# =====================================================
# 复制本文件为 .env.local，填入真实值。

# === Supabase（数据库 + 认证） ===
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xobfnmwaxlswfofmembv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的anon_key
# Service Role Key: 服务端专用（绕过 RLS，永不暴露到前端）
SUPABASE_SERVICE_ROLE_KEY=你的service_role_key

# === DeepSeek（LLM 大语言模型） ===
# 注册: https://platform.deepseek.com → API Keys → Create Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === 火山引擎语音（ASR + TTS） ===
# API Key: 控制台 → API Key 管理 → 创建
# 文档: https://www.volcengine.com/docs/6561/1354867
VOLCENGINE_API_KEY=
# App ID: 控制台 → 语音技术 → 应用管理
VOLCENGINE_APP_ID=

# ASR WebSocket 大模型 endpoint（固定值，一般不改）
VOLCENGINE_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel
# ASR Resource ID（大模型2.0 = volc.seedasr.sauc.duration，大模型1.0 = volc.bigasr.sauc.duration）
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
# ASR 录音文件识别 cluster（HSKK 模考用，需开通「录音文件识别」）
VOLCENGINE_ASR_FILE_CLUSTER=volcengine_bigasr
# TTS cluster（开通「语音合成」后填入）
VOLCENGINE_TTS_CLUSTER=volcano_tts

# === Lemon Squeezy（支付） ===
# 注册: https://app.lemonsqueezy.com
# API Key: Settings → API → Create
LEMONSQUEEZY_API_KEY=你的api_key
# Store ID: Stores 页面复制
LEMONSQUEEZY_STORE_ID=你的store_id
# Webhook Secret: Webhooks → Create → 复制 Signing Secret
# Webhook URL 填: https://app.chatmandarin.cc/api/lemonsqueezy/webhook
LEMONSQUEEZY_WEBHOOK_SECRET=你的signing_secret
# 产品 Variant ID（创建产品后从详情页复制）
LEMONSQUEEZY_PLUS_VARIANT_ID=你的plus_variant_id
LEMONSQUEEZY_PRO_VARIANT_ID=你的pro_variant_id

# === App ===
# 开发: http://localhost:3000 / 生产: https://app.chatmandarin.cc
NEXT_PUBLIC_APP_URL=http://localhost:3000
